# Enterprise Sentinel local configuration

# Required for live model calls. Leave empty for offline syntax and unit checks.
OPENAI_API_KEY=

# Service URLs used by the agent supervisor when running with Docker Compose.
MCP_SERVER_URL=http://localhost:8001
AGENT_SUPERVISOR_URL=http://localhost:8002
RAG_WORKER_URL=http://localhost:8003
SQL_WORKER_URL=http://localhost:8004
VISION_WORKER_URL=http://localhost:8005
GUARDRAIL_URL=http://localhost:8006

# Local data services.
QDRANT_URL=http://localhost:6333
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_pass

# Operational defaults.
LOG_LEVEL=INFO
ENVIRONMENT=local
MAX_AGENT_STEPS=8
DEFAULT_MODEL=gpt-4o-mini

